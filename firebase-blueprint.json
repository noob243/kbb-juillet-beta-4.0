{
  "entities": {
    "client": {
      "title": "Client",
      "description": "Un client du cabinet d'avocats",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "cases": { "type": "number" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
