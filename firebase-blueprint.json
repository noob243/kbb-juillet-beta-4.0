        "ref1_phone": { "type": "string" },
        "ref1_email": { "type": "string" },
        "ref2_nom": { "type": "string" },
        "ref2_phone": { "type": "string" },
        "ref2_email": { "type": "string" },
        "typeFacturation": { "type": "string" }
      },
      "required": ["id", "name", "contact"]
    },
